{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalRecord",
  "version": "0.7.6",
  "identifier": "com.localrecord.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1478",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LocalRecord",
        "width": 980,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520
      },
      {
        "label": "annot",
        "title": "LocalRecord — anotação",
        "url": "annot.html",
        "visible": false,
        "transparent": true,
        "alwaysOnTop": true,
        "decorations": false,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "shadow": false,
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "resources": ["binaries/ffmpeg/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
